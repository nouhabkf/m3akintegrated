# Port du serveur (défaut: 3000)
PORT=3000

# MongoDB - Option 1: URI complète
MONGODB_URI=mongodb://localhost:27017/ma3ak

# MongoDB Atlas - Option 2: Variables séparées
# DB_USERNAME=
# DB_PASSWORD=
# DB_CLUSTER=
# DB_NAME=

# JWT
JWT_SECRET=votre_secret_jwt_tres_securise
JWT_EXPIRES_IN=7d

# CORS (optionnel, séparé par des virgules)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Google OAuth2 (pour login Google)
GOOGLE_CLIENT_ID=votre_google_client_id

# --- Google Cloud Vision (analyse d’image réelle, module Vision) ---
# 1) Activer "Cloud Vision API" sur le projet GCP
# 2) Compte de service → clé JSON → placer le fichier hors du dépôt
# 3) Chemin ABSOLU (Windows : préférer C:/dossier/cle.json)
# GOOGLE_APPLICATION_CREDENTIALS=C:/secrets/ma3ak-gcp-vision.json
# GOOGLE_CLOUD_PROJECT_ID=votre-project-id-gcp
# Guide détaillé : docs/SETUP_GOOGLE_VISION_FR.md

# --- Gemini (Google AI) — analyse photo + FALC du texte détecté (prioritaire sur Ollama si défini) ---
# Clé : https://aistudio.google.com/apikey
# GEMINI_API_KEY=votre_cle
# ou alias : GOOGLE_AI_API_KEY=
# GEMINI_ENABLED=true
# GEMINI_VISION_MODEL=gemini-2.0-flash
# GEMINI_VISION_TIMEOUT_MS=120000

# Développement : ignore la contrainte de rôle (Handicapé/Accompagnant) sur GET .../audio-description
# AUDIO_DESCRIPTION_SKIP_ROLE_CHECK=false

# --- IA communauté (FastAPI Python : plan d’action /assistant) ---
# Démarre : cd ai && uvicorn src.app:app --reload --host 127.0.0.1 --port 8000
AI_COMMUNITY_BASE_URL=http://127.0.0.1:8000
AI_COMMUNITY_TIMEOUT_MS=10000

# --- Ollama (IA locale : simplification FALC, analyse photo LLaVA, urgence, résumés) ---
# Local : « ollama serve » puis « ollama pull » les modèles ci-dessous.
# Si OLLAMA_ENABLED est absent et NODE_ENV≠production → Ollama actif par défaut.
# Production : définir explicitement OLLAMA_ENABLED=true ou false.
OLLAMA_ENABLED=true
# Équivalent : http://localhost:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Backend dans Docker sur Windows/Mac : l’hôte où tourne Ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEXT_MODEL_FALLBACK=llama3.2,llama3,mistral,llava
OLLAMA_TIMEOUT_MS=120000
# Réponse plus rapide : moins de tokens générés / entrée tronquée si très long post
# Prompt FALC court : 120–200 suffit souvent (réponses en 2 phrases)
OLLAMA_SIMPLIFY_NUM_PREDICT=180
OLLAMA_SIMPLIFY_MAX_INPUT_CHARS=3200
OLLAMA_VISION_NUM_PREDICT=640
# Identique au nom dans « ollama list » (ex. llava ou llava:latest — pas d’espace en trop)
OLLAMA_VISION_MODEL=llava
OLLAMA_VISION_MODEL_FALLBACK=llava,llava:latest,bakllava
# Vision souvent >3 min au 1er run (CPU) — 15 min par défaut côté code si absent
OLLAMA_VISION_TIMEOUT_MS=900000
# GET http://localhost:3000/accessibility/features → vérifie la config côté serveur
# Doc : docs/COMMUNAUTE_IA_SANS_FRAIS_FR.md
